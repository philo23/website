# global options
{
	admin off
	persist_config off
	auto_https off

	log {
		format json
	}

	servers {
		trusted_proxies static private_ranges 100.0.0.0/8 # trust railway's proxy
	}
}

# site block, listens on the $PORT environment variable, automatically assigned by railway
:{$PORT:80} {
	log {
		format json
	}

	respond /health 200

	# Security headers
	header {
		# Prevent some browsers from MIME-sniffing a response away from the declared Content-Type
		X-Content-Type-Options "nosniff"
		# Remove Server header
		-Server
		# Add basic caching
		Cache-Control "public, max-age=0, must-revalidate"
	}

	# Cache Astro built assets for longer
	header /_astro/* {
		Cache-Control "public, max-age=31536000, immutable"
	}

	# serve from the 'dist' folder (Vite builds into the 'dist' folder)
	root * {{.DIST_DIR}}

	# Compression with more formats
	encode {
		gzip
		zstd
	}

	# Spotify Now Playing proxy
	handle_path /spotify/* {
		header Cache-Control "no-cache"

		reverse_proxy {env.SPOTIFY_ACTIVITY_SERVICE} {
			flush_interval -1

			header_down X-Robots-Tag "noindex"

			@upstream_not_found status 404

			# Intercept upstream 404 responses
			handle_response @upstream_not_found {
				error 404
			}
		}
	}

	# Handle static files
	handle {
		try_files {path} {path}.html {path}/index.html =404

		file_server {
			hide .git
			hide .env*
		}
	}

	handle_errors {
		@notfound expression `{err.status_code} == 404`
		rewrite @notfound /404.html

		file_server {
			hide .git
			hide .env*
		}
	}
}
